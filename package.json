{
  "name": "pcb-assebmly-checker",
  "version": "0.1.25",
  "author": "Marece Williams",
  "description": "App for programming and testing io-manager PCBs",
  "main": "build/main.js",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@serialport/parser-byte-length": "^13.0.0",
    "@wbm-tek/version-manager": "^0.0.81",
    "electron-updater": "^6.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "react-router-dom": "^7.14.2",
    "serialport": "^13.0.0",
    "wbm-usb-device": "^0.2.60",
    "web-vitals": "^5.2.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "electron": "electron .",
    "package": "SET USE_PNPM=true && SET CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --dir",
    "dist": "pnpm run build && SET USE_PNPM=true && electron-builder",
    "deploy": "pnpm run build && SET USE_PNPM=true && electron-builder --publish always",
    "upload": "pnpm build && git add . && git commit -m %NPM_PACKAGE_VERSION% && git push origin master && pnpm deploy ",
    "try": "pnpm dist",
    "backup": "git add . && git commit -m %NPM_PACKAGE_VERSION% && git push origin master",
    "refresh": "pnpm upgrade --latest",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wbmmusic/assembly-checker.git"
  },
  "build": {
    "productName": "WBM Tek PCB Assembly Checker",
    "appId": "com.electron.pcbchk",
    "copyright": "WBM Tek",
    "extends": null,
    "asar": true,
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "build/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "build/main.js"
    },
    "extraResources": [
      {
        "from": "public/favicon.ico",
        "to": "favicon.ico"
      },
      {
        "from": "app-update.yml",
        "to": "app-update.yml"
      },
      "public/JLink.exe",
      "public/JLinkARM.dll",
      {
        "from": "public/firmware",
        "to": "public/firmware"
      },
      {
        "from": "public/USBDriver",
        "to": "public/USBDriver"
      },
      {
        "from": "public/boardfiles",
        "to": "public/boardfiles"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "certificateSha1": "b281b2c2413406e54ac73f3f3b204121b4a66e64",
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      }
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PCB Assembly Checker",
      "perMachine": false,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "s3",
      "bucket": "wbm-tek-version-manager-bucket",
      "region": "us-east-2",
      "path": "releases/pcb-assembly-checker",
      "acl": null
    }
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac"
}
